{
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 200,
      "title": "Cycle Duration (Latency)",
      "type": "row"
    },
    {
      "datasource": {
        "uid": "prometheus"
      },
      "description": "Template: average request/operation latency per service",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10
          },
          "unit": "us"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "targets": [
        {
          "expr": "rate(elixir_stress_app_cycle_duration_duration_sum[1m]) / rate(elixir_stress_app_cycle_duration_duration_count[1m])",
          "legendFormat": "{{worker}}"
        }
      ],
      "title": "Avg Cycle Duration by Worker",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "prometheus"
      },
      "description": "Template: P95 latency per service (histogram_quantile)",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10
          },
          "unit": "us"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (worker, le) (rate(elixir_stress_app_cycle_duration_duration_bucket[1m])))",
          "legendFormat": "p95 {{worker}}"
        }
      ],
      "title": "P95 Cycle Duration by Worker",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "prometheus"
      },
      "description": "Template: latency distribution heatmap",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "id": 3,
      "options": {
        "calculate": false,
        "color": {
          "scheme": "Turbo"
        },
        "yAxis": {
          "unit": "us"
        }
      },
      "targets": [
        {
          "expr": "sum by (le) (increase(elixir_stress_app_cycle_duration_duration_bucket[30s]))",
          "format": "heatmap",
          "legendFormat": "{{le}}"
        }
      ],
      "title": "Cycle Duration Heatmap (All Workers)",
      "type": "heatmap"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 17
      },
      "id": 201,
      "title": "Memory Operations",
      "type": "row"
    },
    {
      "datasource": {
        "uid": "prometheus"
      },
      "description": "Template: current resource utilization gauge (e.g. queue depth, cache size)",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2
          },
          "unit": "decbytes"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 18
      },
      "id": 4,
      "targets": [
        {
          "expr": "elixir_stress_app_memory_held_bytes",
          "legendFormat": "Held Bytes"
        }
      ],
      "title": "Memory Held (Current)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "prometheus"
      },
      "description": "Template: items in queue/buffer",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 18
      },
      "id": 5,
      "targets": [
        {
          "expr": "elixir_stress_app_memory_held_chunks",
          "legendFormat": "Chunks Held"
        }
      ],
      "title": "Memory Chunks Held",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "prometheus"
      },
      "description": "Template: throughput in vs out (e.g. enqueue vs dequeue rate)",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10
          },
          "unit": "Bps"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Released"
            },
            "properties": [
              {
                "id": "custom.transform",
                "value": "negative-Y"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 18
      },
      "id": 6,
      "targets": [
        {
          "expr": "rate(elixir_stress_app_memory_allocated_bytes_total[1m])",
          "legendFormat": "Allocated"
        },
        {
          "expr": "rate(elixir_stress_app_memory_released_bytes_total[1m])",
          "legendFormat": "Released"
        }
      ],
      "title": "Memory Allocated vs Released (rate/s)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "prometheus"
      },
      "description": "Template: total throughput counter",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "unit": "decbytes"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 26
      },
      "id": 7,
      "targets": [
        {
          "expr": "elixir_stress_app_memory_allocated_bytes_total",
          "legendFormat": "Total Allocated"
        }
      ],
      "title": "Cumulative Memory Allocated",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 30
      },
      "id": 202,
      "title": "Disk I/O Throughput",
